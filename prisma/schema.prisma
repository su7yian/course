// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}
// ─────────────────────────────────────────────────────────────────────────────
model Song {
  id           Int   @id @default(autoincrement())
  creatorId    Int?   @map("creator_id")
  title        String
  playlistId   Int?
  artists      Artist[] @relation("SongsArtist") // m to m: m
  releaseDate  DateTime @default(now())
  duration     Int
  lyrics       String?

  playlist    Playlist?  @relation("playlistSongs",fields: [playlistId],references: [id]) // m to o : m
  creator      User?  @relation("songsCreator", fields: [creatorId], references: [id]) // m to o : m ont creaotr creates many current model songs
  @@map("songs")
}
model User {
 id            Int  @id @default(autoincrement())
 firstName     String
 lastName      String
 email         String   @unique
 password      String
 refreshToken  String?
 createdSongs  Song[] @relation("songsCreator") // o to m: o
 savedPlaylists Playlist[] @relation("UsersPlaylist") // o to m : o
 isArtist      Artist? // o to o: o1
 tokenVersion  Int @default(0)
 @@map("users")
}
model Artist {
  id   Int      @id @default(autoincrement())
  userId Int    @unique  @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade) // o to o: o2
  // Prisma handles many-to-many automatically when both sides are arrays [].
  songs Song[]    @relation("SongsArtist") // m to m :  m
  @@map("artists")
}

model Playlist{
  id   Int      @id @default(autoincrement())
  userId Int? @map("user_id")
  name  String
  songs Song[] @relation("playlistSongs") //o to m: o
  // many playlsits can belong to single user m to o : m
  users User? @relation("UsersPlaylist", fields: [userId], references: [id])  // m to o: m
}
